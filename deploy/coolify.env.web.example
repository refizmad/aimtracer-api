# Paste into Coolify → web (aimtracer.com) service → Environment.

NODE_ENV=production

# Internal Coolify DNS to the api service (container port 5500).
# Change "api" if your Coolify service name differs.
CLIPPER_BACKEND_URL=http://api:5500

# Required in production: public browser origin (Steam OpenID return_to + redirects).
# Without this, Next may use http://localhost:3000 behind Coolify's reverse proxy.
NEXT_PUBLIC_SITE_URL=https://aimtracer.com
SITE_URL=https://aimtracer.com
