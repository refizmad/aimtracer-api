# Copy to deploy/.env and fill every required value.
# NEVER commit deploy/.env

# --- Public hostname (Caddy + Let's Encrypt) ---
API_DOMAIN=api.aimtracer.com

# --- Postgres (compose creates the role/db) ---
POSTGRES_USER=aimtrace
POSTGRES_PASSWORD=change_me_long_random
POSTGRES_DB=aimtrace
# DATABASE_URL is set by compose to the internal db service; override only if needed.

# --- API ---
PORT=5500
NODE_ENV=production

# Public web origin for Steam OpenID return_to allowlist (aimtrace site).
# Must match the browser origin friends use (https://aimtracer.com).
AUTH_RETURN_BASE_URL=https://aimtracer.com

# Strong secrets (generate with openssl rand -hex 32 / node crypto)
ADMIN_TOKEN=
BOOTSTRAP_TOKEN=
CREDENTIALS_ENCRYPTION_KEY=
# base64 32 bytes: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Steam Web API (match history poller + persona)
STEAM_WEBAPI_KEY=

# Poller — leave false until a friend is enrolled and worker is ready (M8)
MATCH_HISTORY_POLL_ENABLED=false
MATCH_HISTORY_MAX_PAGES=15
MAX_AUTO_JOBS_PER_PLAYER_PER_DAY=10
MAX_GLOBAL_QUEUE_DEPTH=50

# Worker seed (optional; seed script / bootstrap also works)
SEED_WORKER_TOKEN=

# Lease
LEASE_VISIBILITY_TIMEOUT=300
MAX_LEASE_WAIT_SECONDS=25

# --- Private clip media (ADR-0004): read-only S3 keys on the API ---
S3_ENDPOINT_URL=https://xxxx.va.idrivee2-11.com
S3_BUCKET=aimtracer-clips
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_PREFIX=clips
S3_PRESIGN_EXPIRY=3600

# Optional backup upload target (same bucket OK; use a backups/ prefix)
S3_BACKUP_PREFIX=backups/postgres
