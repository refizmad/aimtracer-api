# Database
DATABASE_URL="postgresql://aimtrace:aimtrace@localhost:5432/aimtrace?schema=public"

# Server
PORT=5500
NODE_ENV=development
# Nest + Fastify log level: fatal|error|warn|info|debug|trace|silent
# LOG_LEVEL=info

# Rate limiting (per client IP; Coolify sets X-Forwarded-For — trustProxy is on)
# Default: 120 requests / 60s. Auth/bootstrap use tighter per-route limits.
# Worker machine-token requests are not throttled (long-poll lease).
# RATE_LIMIT_TTL_MS=60000
# RATE_LIMIT_MAX=120

# Public web origin(s) for Steam OpenID return_to allowlist (comma-separated OK).
# localhost and 127.0.0.1 are treated as aliases of each other on the same port.
AUTH_RETURN_BASE_URL=http://127.0.0.1:3000

# Admin: create invites via POST /admin/invites (X-Admin-Token)
# Also accepts X-Bootstrap-Token with the same value for local convenience.
ADMIN_TOKEN=dev_admin_token_please_change

# Steam Web API key (required for match-history enroll + poll; also used for persona)
# https://steamcommunity.com/dev/apikey
STEAM_WEBAPI_KEY=
# STEAM_API_KEY=

# AES-256-GCM key for match-history auth codes (base64 of 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIALS_ENCRYPTION_KEY=

# Match history poller (cron every 10m when true)
MATCH_HISTORY_POLL_ENABLED=false
MATCH_HISTORY_MAX_PAGES=15
MAX_AUTO_JOBS_PER_PLAYER_PER_DAY=10
MAX_GLOBAL_QUEUE_DEPTH=50

# Worker auth (prefer DB workers table via seed)
# SEED_WORKER_TOKEN=dev_machine_token_please_change

# Lease config (seconds)
LEASE_VISIBILITY_TIMEOUT=300
MAX_LEASE_WAIT_SECONDS=25

# Optional: bootstrap token to register new workers via POST /bootstrap/worker
# BOOTSTRAP_TOKEN=super-secret-bootstrap-only

# Optional fixed invite code for seed
# SEED_INVITE_CODE=FRIENDS2026

# Private-bucket clip playback (ADR-0004). Read-only keys are enough for GET presigns.
# When unset in non-production, media falls back to CLIP_MEDIA_DEV_FALLBACK_URL (sample mp4).
# S3_ENDPOINT_URL=https://xxxx.va.idrivee2-11.com
# S3_BUCKET=aimtracer-clips
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_PREFIX=clips
# S3_PRESIGN_EXPIRY=3600
# CLIP_MEDIA_DEV_FALLBACK_URL=https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4
