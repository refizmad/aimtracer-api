# Paste into Coolify → api service → Environment.
# Replace placeholders; never commit real values.

NODE_ENV=production
PORT=5500

# Coolify Postgres (internal hostname — use the name Coolify shows)
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/aimtrace?schema=public

AUTH_RETURN_BASE_URL=https://aimtracer.com

ADMIN_TOKEN=
BOOTSTRAP_TOKEN=
CREDENTIALS_ENCRYPTION_KEY=
STEAM_WEBAPI_KEY=

MATCH_HISTORY_POLL_ENABLED=false
MATCH_HISTORY_MAX_PAGES=15
MAX_AUTO_JOBS_PER_PLAYER_PER_DAY=10
MAX_GLOBAL_QUEUE_DEPTH=50
LEASE_VISIBILITY_TIMEOUT=300
MAX_LEASE_WAIT_SECONDS=25

S3_ENDPOINT_URL=
S3_BUCKET=aimtracer-clips
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_PREFIX=clips
S3_PRESIGN_EXPIRY=3600

# Logging + rate limits (optional)
# LOG_LEVEL=info
# RATE_LIMIT_TTL_MS=60000
# RATE_LIMIT_MAX=120
