generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  LEASED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PlayerStatus {
  ACTIVE
  DISABLED
}

enum EnrollmentStatus {
  ACTIVE
  DISABLED
  INVALID_AUTH
  CHAIN_BROKEN
}

enum JobSource {
  manual
  auto_match_history
}

enum MatchStatus {
  DETECTED
  DOWNLOADED
  RENDERED
  FAILED
}

model Worker {
  id           String    @id @default(uuid())
  name         String
  machineToken String    @unique @map("machine_token")
  enabled      Boolean   @default(true)
  lastSeenAt   DateTime? @map("last_seen_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  jobs Job[]

  @@map("workers")
}

model Player {
  id          String       @id @default(uuid())
  steamId64   String       @unique @map("steam_id64")
  displayName String?      @map("display_name")
  avatarUrl   String?      @map("avatar_url")
  status      PlayerStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  sessions   Session[]
  inviteUsed Invite?                  @relation("InviteUsedBy")
  jobs       Job[]
  enrollment MatchHistoryEnrollment?
  matches    Match[]
  clips      Clip[]

  @@map("players")
}

model Session {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  playerId  String   @map("player_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([expiresAt])
  @@map("sessions")
}

model Invite {
  id        String    @id @default(uuid())
  code      String    @unique
  note      String?
  maxUses   Int       @default(1) @map("max_uses")
  useCount  Int       @default(0) @map("use_count")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  usedById  String?   @unique @map("used_by_id")
  usedBy    Player?   @relation("InviteUsedBy", fields: [usedById], references: [id])

  @@map("invites")
}

/// Short-lived OpenID state for CSRF protection on Steam login.
model AuthState {
  id         String   @id @default(uuid())
  state      String   @unique
  inviteCode String?  @map("invite_code")
  returnTo   String   @map("return_to")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("auth_states")
}

/// Match history auth for auto-clip. Row exists only after first successful enroll.
model MatchHistoryEnrollment {
  id                 String           @id @default(uuid())
  playerId           String           @unique @map("player_id")
  status             EnrollmentStatus @default(ACTIVE)
  /// AES-256-GCM package: v1:ivB64:tagB64:ctB64
  authCodeCiphertext String           @map("auth_code_ciphertext")
  authCodeLast4      String           @map("auth_code_last4")
  knownShareCode     String           @map("known_share_code")
  /// Cursor tip for GetNextMatchSharingCode (starts as anchor; only advances after enqueue).
  lastShareCode      String           @map("last_share_code")
  lastPolledAt       DateTime?        @map("last_polled_at")
  lastError          String?          @map("last_error")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("match_history_enrollments")
}

/// A player's match, keyed by share code. Evolved from MatchShareCode: still
/// the discovery/dedup row (no row for the enrollment anchor alone), now also
/// the first-class dashboard entity with lifecycle status and demo metadata.
model Match {
  id           String      @id @default(uuid())
  playerId     String      @map("player_id")
  shareCode    String      @map("share_code")
  status       MatchStatus @default(DETECTED)
  /// Map name (e.g. de_mirage); learned from the first ingested clip.
  map          String?
  demoName     String?     @map("demo_name")
  /// Best-known match time. Discovery/submission time for now; a better
  /// source (demo header) can overwrite it later.
  matchDate    DateTime    @map("match_date")
  jobId        String?     @unique @map("job_id")
  discoveredAt DateTime    @default(now()) @map("discovered_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  job    Job?   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  clips  Clip[]

  @@unique([playerId, shareCode])
  @@index([playerId, jobId])
  @@index([playerId, status])
  @@map("matches")
}

/// A rendered highlight clip, ingested from a worker's COMPLETED job result
/// (metadata originates in the clipper's <clip>.json sidecars).
model Clip {
  id            String   @id @default(uuid())
  /// Short public share slug for /clip/:code (UUID stays internal).
  publicCode    String   @unique @map("public_code")
  playerId      String?  @map("player_id")
  matchId       String?  @map("match_id")
  jobId         String?  @map("job_id")
  /// mp4 basename -- also the S3 object key and the manifest's dedup key,
  /// which is why it is globally unique (a re-render overwrites in S3 too).
  file          String   @unique
  url           String?
  sizeBytes     Int?     @map("size_bytes")
  /// Sidecar "type": e.g. 2k/3k/4k/ace/clutch (moment type).
  clipType      String?  @map("clip_type")
  map           String?
  round         Int?
  kills         Int?
  headshots     Int?
  score         Int?
  durationS     Float?   @map("duration_s")
  specials      Json?
  clutch        Json?
  killEvents    Json?    @map("kill_events")
  /// Player display name at render time (names are spoofable; steamid is truth).
  playerName    String?  @map("player_name")
  playerSteamId String?  @map("player_steamid")
  demoName      String?  @map("demo_name")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  match  Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)
  job    Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([playerId, createdAt])
  @@index([matchId])
  @@index([kills])
  @@index([clipType])
  @@map("clips")
}

model Job {
  id     String    @id @default(uuid())
  type   String    @default("clip")
  status JobStatus @default(PENDING)
  source JobSource @default(manual)

  // What the worker should do
  payload Json

  // Optional ownership (friends clip dashboard)
  playerId  String? @map("player_id")
  shareCode String? @map("share_code")

  // Leasing / visibility timeout
  leasedBy       String?   @map("leased_by")
  leasedAt       DateTime? @map("leased_at")
  leaseExpiresAt DateTime? @map("lease_expires_at")

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  // Progress reporting
  progress Int     @default(0)
  stage    String?
  message  String?
  result   Json?
  error    String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  worker    Worker?         @relation(fields: [leasedBy], references: [id])
  player    Player?         @relation(fields: [playerId], references: [id], onDelete: SetNull)
  match     Match?
  clips     Clip[]

  @@index([status, leaseExpiresAt])
  @@index([createdAt])
  @@index([playerId])
  @@index([playerId, shareCode])
  @@index([source, status, createdAt])
  @@map("jobs")
}
